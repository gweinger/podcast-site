---
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import { LINKS } from '../lib/links';
interface Props { title: string; description?: string; canonical?: string; }
const { title, description = '', canonical } = Astro.props;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />
    <slot name="head" />
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a class="brand" href="/">Greg Weinger</a>
        <nav>
          <a href="/podcast/introverted-leader/">Podcast</a>
          <a href="/topics/">Topics</a>
          <a href="/introvert-army/">Army</a>
          <a href="/about">About</a>
          <a class="nav-cta" href={LINKS.newsletter}>Subscribe</a>
        </nav>
      </div>
    </header>
    <main class="container"><slot /></main>
    <Footer />
  </body>
</html>
