---
import { PERSON } from '../lib/person';
const data = {
  '@context': 'https://schema.org',
  '@graph': [
    PERSON,
    {
      '@type': 'WebSite',
      '@id': 'https://gweinger.com/#website',
      name: 'Greg Weinger',
      url: 'https://gweinger.com/',
      publisher: { '@id': PERSON['@id'] },
    },
  ],
};
---
<script type="application/ld+json" is:inline set:html={JSON.stringify(data)} />
