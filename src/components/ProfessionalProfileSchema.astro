---
interface Props {
  name: string;
  website: string;
  jobTitle: string;
  bio: string;
  linkedin?: string;
  instagram?: string;
}
const { name, website, jobTitle, bio, linkedin, instagram } = Astro.props;
const sameAs = [website, linkedin, instagram].filter((v): v is string => Boolean(v));
const data = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name,
  url: website,
  jobTitle,
  description: bio.slice(0, 200),
  ...(sameAs.length > 0 ? { sameAs } : {}),
};
---
<script type="application/ld+json" is:inline set:html={JSON.stringify(data)} />
