---
import { PERSON } from '../lib/person';
interface Props {
  title: string;
  description: string;
  url: string; // canonical hub url, e.g. https://gweinger.com/topics/imposter-syndrome/
  episodes: { title: string; url: string }[];
}
const { title, description, url, episodes } = Astro.props;
const data = {
  '@context': 'https://schema.org',
  '@graph': [
    PERSON,
    {
      '@type': 'CollectionPage',
      '@id': `${url}#page`,
      name: title,
      description,
      url,
      about: { '@id': PERSON['@id'] },
      mainEntity: {
        '@type': 'ItemList',
        itemListElement: episodes.map((e, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: e.title,
          url: e.url,
        })),
      },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Topics', item: 'https://gweinger.com/topics/' },
        { '@type': 'ListItem', position: 2, name: title, item: url },
      ],
    },
  ],
};
---
<script type="application/ld+json" is:inline set:html={JSON.stringify(data)} />
