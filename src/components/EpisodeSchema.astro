---
import { PERSON, SERIES } from '../lib/person';
interface Props {
  title: string; description: string; url: string;
  episodeNumber: number; datePublished?: Date; audioUrl?: string;
}
const { title, description, url, episodeNumber, datePublished, audioUrl } = Astro.props;
const data = {
  '@context': 'https://schema.org',
  '@graph': [
    PERSON,
    SERIES,
    {
      '@type': 'PodcastEpisode',
      url,
      name: title,
      description,
      episodeNumber,
      ...(datePublished ? { datePublished: datePublished.toISOString().slice(0, 10) } : {}),
      ...(audioUrl ? { associatedMedia: { '@type': 'MediaObject', contentUrl: audioUrl } } : {}),
      partOfSeries: { '@id': SERIES['@id'] },
      author: { '@id': PERSON['@id'] },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Podcast', item: 'https://gweinger.com/podcast/introverted-leader/' },
        { '@type': 'ListItem', position: 2, name: title, item: url },
      ],
    },
  ],
};
---
<script type="application/ld+json" is:inline set:html={JSON.stringify(data)} />
