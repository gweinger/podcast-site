---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { PILLARS, partitionEpisodes, type EpisodeLike } from '../../lib/pillars';

const topics = (await getCollection('topics')).sort((a, b) => a.data.order - b.data.order);

// Guard: every pillar must have exactly one hub file (catches a forgotten topic).
if (topics.length !== PILLARS.length) {
  throw new Error(`Expected ${PILLARS.length} topic hubs, found ${topics.length}`);
}

const allEpisodes = (await getCollection('episodes')) as unknown as EpisodeLike[];
const counts = new Map<string, number>();
for (const t of topics) {
  const { core, secondary, minisodes } = partitionEpisodes(allEpisodes, t.data.pillar);
  counts.set(t.data.slug, core.length + secondary.length + minisodes.length);
}
---
<Base title="Topics — Greg Weinger" description="Browse Greg Weinger's writing and podcast conversations by topic: imposter syndrome, speaking up, visibility, executive presence, energy, and promotion for introverted leaders.">
  <div class="container">
  <h1>Topics</h1>
  <p>The themes behind The Introverted Leader — each with the conversations and resources that go deepest on it.</p>

  <div class="card-grid topic-hub-grid">
    {topics.map((t) => (
      <a class="card topic-hub-card" href={`/topics/${t.data.slug}/`}>
        <h2 class="topic-hub-name">{t.data.navLabel ?? t.data.title}</h2>
        <p class="topic-meta">{t.data.metaDescription}</p>
        <div class="topic-hub-chips">
          {t.data.painChips.map((c) => <span class="pain-chip">{c}</span>)}
        </div>
        <span class="topic-hub-count">{counts.get(t.data.slug)} episodes</span>
      </a>
    ))}
  </div>
  </div>
</Base>
